# Copier ce fichier en .env.local pour le développement local
# Ces variables doivent aussi être ajoutées dans Vercel > Settings > Environment Variables

# Supabase — https://app.supabase.com > Project Settings > API
SUPABASE_URL=https://VOTRE_PROJET.supabase.co
SUPABASE_SERVICE_KEY=votre_service_role_key   # ⚠️ Ne jamais exposer côté client

# JWT — clé secrète aléatoire (ex: openssl rand -hex 32)
JWT_SECRET=remplacez_par_une_chaine_aleatoire_longue
